# =============================================================================
# Backend (Render) env vars
# =============================================================================

# Neon Postgres connection string — get from Neon dashboard.
# IMPORTANT: keep the `?sslmode=require&channel_binding=require` suffix.
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require&channel_binding=require

# Production mode (Render auto-sets this from render.yaml, listed here for local dev)
NODE_ENV=production

# Comma-separated list of allowed frontend origins for CORS
# (Vercel preview URL + production domain + custom domain)
ALLOWED_ORIGINS=https://your-site.vercel.app,https://yourdomain.com

# JWT signing secret — any random ≥32-char string. Render auto-generates this.
JWT_SECRET=

# Admin API key for protected admin routes. Render auto-generates this.
ADMIN_API_KEY=

# Email recipient for lead-form notifications via FormSubmit
LEAD_NOTIFY_TO=teddy.nk28@gmail.com

# =============================================================================
# Stripe (optional — only if this site sells)
# =============================================================================
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# =============================================================================
# Frontend (Vercel) build env vars
# These are set in vercel.json's buildCommand, NOT here.
# Listed for reference only:
#   PORT=3000          # any value — required by vite.config.ts at build time
#   BASE_PATH=/        # site base path (always / for top-level deploys)
# =============================================================================
