# ──────────────────────────────────────────────────────────────────────────
# Backend env vars — set these on Render (Settings → Environment).
# Render Blueprint (render.yaml) auto-prompts for the ones marked REQUIRED.
# ──────────────────────────────────────────────────────────────────────────

# REQUIRED — Neon connection string for THIS client's database.
# Create a new Neon project per client. Copy from Neon dashboard → Connection string.
DATABASE_URL=postgresql://neondb_owner:PASSWORD_HERE@ep-xxx.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# REQUIRED — comma-separated list of frontend origins allowed to call the API.
ALLOWED_ORIGINS=https://yoursite.com,https://www.yoursite.com

# Always production for deployed instances.
NODE_ENV=production

# Render expects 10000.
PORT=10000

# AUTO-GENERATED by Render Blueprint — overwrite if you want a specific value.
# Used to log into the admin dashboard at /admin.
ADMIN_PASSWORD=GENERATE_RANDOM_20_CHARS_OR_LET_RENDER_DO_IT

# AUTO-GENERATED by Render Blueprint — HMAC key for admin sessions.
# Must be 64 hex chars. Don't share. Rotate if leaked.
SESSION_SECRET=GENERATE_RANDOM_64_CHAR_HEX_OR_LET_RENDER_DO_IT

# Where lead/quote-form notifications get emailed.
# Default to teddy.nk28@gmail.com (already FormSubmit-activated).
# Switch to client's email ONLY after probing FormSubmit and confirming success: "true".
LEAD_NOTIFY_TO=teddy.nk28@gmail.com

# ──────────────────────────────────────────────────────────────────────────
# Optional — only set these if the site needs them.
# ──────────────────────────────────────────────────────────────────────────

# Stripe (payments) — only if the site sells anything.
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...    # set this AFTER creating the webhook in Stripe dashboard

# Override the default FormSubmit sender display name (rare).
# NOTIFY_GMAIL_USER=teddy.nk28@gmail.com
